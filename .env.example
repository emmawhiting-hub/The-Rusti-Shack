# Copy this file to .env.local for local development.
# Never commit .env.local or any file containing real values.
# Add these same variable names (with real values) in Netlify:
#   Site configuration → Environment variables

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
SUPABASE_SECRET_KEY=sb_secret_...
MANAGER_PASSWORD=choose-a-strong-password
# Free Gemini API key (create with a personal Gmail, not a BYUI account),
# powers the management-only "Ask the Data" assistant. Server-side only.
GEMINI_API_KEY=AIza...
